{
  "name": "kiryxawxmx",
  "version": "1.0.0",
  "description": "Автоматизация настройки ПК",
  "author": "kiryxawxmx",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "release": "electron-builder --win portable --publish always"
  },
  "build": {
    "appId": "com.kiryxawxmx.app",
    "productName": "kiryxawxmx",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "node_modules/execa/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/universalify/**/*",
      "assets/**/*",
      "*.html",
      "*.js",
      "*.css",
      "*.yml"
    ],
    "win": {
      "icon": "icon.ico",
      "target": "portable",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "portable": {
      "artifactName": "kiryxawxmx.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "kiryxawxmx",
      "repo": "kiryxawxmx-updater"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "execa": "^5.1.1",
    "electron-updater": "^6.1.7",
    "fs-extra": "^11.2.0",
    "universalify": "^2.0.1"
  }
}
