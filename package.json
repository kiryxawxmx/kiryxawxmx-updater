{
  "name": "kiryxawxmx",
  "version": "1.0.2",
  "description": "Автоматизация настройки ПК для магазина",
  "author": "kiryxawxmx",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.kiryxawxmx.app",
    "productName": "kiryxawxmx",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "win": {
      "icon": "icon.ico",
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator",
      "publisherName": "kiryxawxmx"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "kiryxawxmx",
      "artifactName": "kiryxawxmx_Setup_${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "kiryxawxmx",
      "repo": "kiryxawxmx-updater",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "execa": "^5.1.1",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0",
    "lazy-val": "^1.0.5",
    "lodash.escaperegexp": "^4.1.2",
    "lodash.isequal": "^4.5.0",
    "semver": "^7.6.0",
    "tiny-typed-emitter": "^2.1.0"
  }
}
